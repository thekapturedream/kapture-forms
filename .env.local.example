# Kapture Forms · environment variables (example)
# Copy to .env.local and fill in real values for local dev.

# ----------------------------------------------------------
# Supabase
# Project: kapture-forms (separate from kapture-care)
# Provision via supabase.com → New project → "kapture-forms"
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------
# Stripe
# Test keys for local, live keys for production via Vercel env.
# Connect client ID is the platform identifier for publisher payouts.
# ----------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Optional — pre-created price IDs. Leave blank to use inline price_data.
STRIPE_PRICE_STAFF_ONBOARDING_ONEOFF=
STRIPE_PRICE_STAFF_ONBOARDING_SUB=

# ----------------------------------------------------------
# Site
# ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://kapture-forms.com

# ----------------------------------------------------------
# Analytics + errors
# ----------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
SENTRY_DSN=
SENTRY_ORG=kapture
SENTRY_PROJECT=kapture-forms

# ----------------------------------------------------------
# Marketing
# Resend or Postmark for transactional email (magic links, receipts).
# ----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Kapture Forms <forms@kapture.com>"

# ----------------------------------------------------------
# AI
# Used for narrative drafts, anomaly detection, weekly digests.
# ----------------------------------------------------------
ANTHROPIC_API_KEY=
